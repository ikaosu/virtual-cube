# Copy this file to .env.local and fill in real values from your Supabase project.
# Project Settings → API in the Supabase dashboard.
# .env.local is gitignored — these values must NEVER be committed.

# Public values (also exposed to the browser).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-public-key

# Server-only secret. Bypasses RLS — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Public URL of the GitHub repository (shown in the footer for GPL compliance).
# Optional during development; required when deploying to satisfy GPL §6.
NEXT_PUBLIC_REPO_URL=

# Password protecting the /admin panel (list/delete solves).
# Must be at least 4 chars. If unset, /admin endpoints return 503.
ADMIN_PASSWORD=
